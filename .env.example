# ===== Atlas Trading System v5.0 — 環境變數範本 =====

# --- Database (PostgreSQL) ---
ATLAS_DB_HOST=localhost
ATLAS_DB_PORT=5432
ATLAS_DB_NAME=atlas
ATLAS_DB_USER=atlas
ATLAS_DB_PASSWORD=

# --- Cache (Redis) ---
ATLAS_REDIS_HOST=localhost
ATLAS_REDIS_PORT=6379
ATLAS_REDIS_DB=0
ATLAS_REDIS_PASSWORD=

# --- Quote Sources ---
ATLAS_QUOTE_PRIMARY=fugle
ATLAS_QUOTE_SECONDARY=yfinance
ATLAS_QUOTE_TERTIARY=twse_openapi
FUGLE_API_KEY=
CAPITAL_API_KEY=

# --- Notification: Discord ---
DISCORD_WEBHOOK_URL=

# --- Notification: LINE ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- Notification: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notification: Email ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# --- Risk Parameters ---
ATLAS_STOP_LOSS_PCT=0.07
ATLAS_TARGET_R=2.0
ATLAS_MAX_POSITION_PCT=0.20
ATLAS_MAX_TOTAL_EXPOSURE=0.80

# --- Authentication ---
ATLAS_USERNAME=admin
ATLAS_PASSWORD=atlas2026

# --- Debug ---
ATLAS_DEBUG=false
